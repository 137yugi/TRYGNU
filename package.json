{
  "name": "stream-raid-arena",
  "version": "2.0.0",
  "description": "Fantasy livestream nunchaku survivor rebuilt with Phaser, TypeScript, and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "assets:pixel": "node scripts/generate_pixel_assets.mjs",
    "build": "vite build --outDir dist/web --configLoader runner",
    "check": "tsc --noEmit",
    "test": "npm run check && npm run test:no-snap && npm run build",
    "test:smoke": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_smoke.json --iterations 3 --pause-ms 260 --screenshot-dir output/stream-raid-smoke",
    "test:wave": "node web_game_playwright_client.mjs --url 'http://127.0.0.1:5173?seed=wave-clear' --actions-file test_actions_wave_clear.json --iterations 4 --pause-ms 260 --screenshot-dir output/stream-raid-wave",
    "test:equip": "node scripts/test_equipment_catalog.mjs",
    "test:effects": "node scripts/test_skill_effects.mjs",
    "test:nunchaku:inertia": "node scripts/test_nunchaku_inertia.mjs",
    "test:asset:integrity": "node scripts/validate_asset_integrity.mjs",
    "test:responsive": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_responsive.json --viewport 844x390 --iterations 2 --pause-ms 220 --screenshot-dir output/stream-raid-responsive",
    "test:responsive:webkit": "node web_game_playwright_client.mjs --browser webkit --url http://127.0.0.1:5173 --actions-file test_actions_responsive.json --viewport 844x390 --iterations 2 --pause-ms 220 --screenshot-dir output/stream-raid-responsive-webkit",
    "test:portrait": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_responsive.json --viewport 390x844 --iterations 3 --pause-ms 220 --screenshot-dir output/stream-raid-portrait",
    "test:relative-drag": "JOYSTICK_TOUCH_BROWSER=chromium JOYSTICK_TOUCH_VIEWPORT=390x844 node scripts/test_virtual_joystick_touch_drag.mjs",
    "test:relative-drag:webkit": "JOYSTICK_TOUCH_BROWSER=webkit JOYSTICK_TOUCH_VIEWPORT=390x844 node scripts/test_virtual_joystick_touch_drag.mjs",
    "test:orientation": "node scripts/test_orientation_resize.mjs",
    "test:forms": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_mobile_menu_forms.json --viewport 390x844 --iterations 5 --pause-ms 220 --screenshot-dir output/stream-raid-menu-forms",
    "test:ad": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_ad_obstacle.json --viewport 932x430 --iterations 4 --pause-ms 260 --screenshot-dir output/stream-raid-ad-obstacle",
    "test:ad:lanes": "node scripts/test_ad_safe_lanes.mjs",
    "test:ad:config": "node scripts/validate_ad_config.mjs",
    "test:longrun": "node web_game_playwright_client.mjs --url 'http://127.0.0.1:5173?boss_debug=1&seed=longrun' --actions-file test_actions_boss_longrun_safe.json --click-selector '#startBtn' --iterations 14 --pause-ms 280 --screenshot-dir output/stream-raid-longrun",
    "test:endless": "node scripts/test_endless_wave_scaling.mjs",
    "test:live:hook": "node web_game_playwright_client.mjs --url http://127.0.0.1:5173 --actions-file test_actions_live_hook.json --iterations 4 --pause-ms 240 --screenshot-dir output/stream-raid-live",
    "test:live:queue": "node scripts/test_live_queue.mjs",
    "test:live:variety": "node scripts/test_live_event_variety.mjs",
    "test:live:terminal": "node scripts/test_terminal_live_input.mjs",
    "test:live:terminal-helper:poll": "node scripts/test_terminal_live_helper_bridge_poll.mjs",
    "test:live:terminal-helper:health": "node scripts/test_terminal_live_helper_bridge_health.mjs",
    "test:live:terminal-helper:connect": "node scripts/test_terminal_live_helper_bridge_connect.mjs",
    "test:live:terminal-helper:stream": "node scripts/test_terminal_live_helper_bridge_stream.mjs",
    "test:live:terminal-helper:stream-open-error": "node scripts/test_terminal_live_helper_bridge_stream_open_error.mjs",
    "test:live:terminal-helper": "npm run test:live:terminal-helper:poll && npm run test:live:terminal-helper:health && npm run test:live:terminal-helper:connect && npm run test:live:terminal-helper:stream && npm run test:live:terminal-helper:stream-open-error",
    "test:live:ui": "node scripts/test_tiktok_live_overlay_ui.mjs",
    "test:live": "npm run test:live:hook && npm run test:live:queue && npm run test:live:variety && npm run test:live:terminal && npm run test:live:terminal-helper && npm run test:bridge:endpoints && npm run test:live:ui",
    "live:bridge:tiktok": "node scripts/tiktok_live_bridge.mjs",
    "test:bridge:endpoints": "node scripts/test_tiktok_live_bridge_endpoints.mjs",
    "test:live:storm": "node scripts/test_live_storm.mjs",
    "test:no-snap": "node scripts/assert_no_snap_residue.mjs",
    "test:storage": "node scripts/test_storage_failure.mjs",
    "test:season:storage": "node scripts/test_storage.mjs",
    "test:online:state": "node scripts/test_online_state_contract.mjs",
    "test:online:terminal-helper": "node scripts/test_online_terminal_helper.mjs",
    "test:postdeploy:mobile": "node scripts/test_post_deploy_mobile_verification.mjs",
    "test:reward:auto": "node scripts/test_reward_auto_resolve.mjs",
    "test:level:draft": "node scripts/test_level_draft_variety.mjs",
    "test:melee:slash": "node scripts/test_melee_slash_build_ui.mjs",
    "test:start:style:rare": "node scripts/test_start_style_rare_spectacle.mjs",
    "test:style:applause:slot": "node scripts/test_style_applause_slot.mjs"
  },
  "keywords": [
    "phaser",
    "survivor",
    "livestream"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "phaser": "^4.0.0",
    "playwright": "^1.58.2",
    "tiktok-live-connector": "^2.1.1-beta1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
